<UserControl x:Class="SSHHelper.App.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SSHHelper.App.ViewModels"
             MinHeight="600" MinWidth="600">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <materialDesign:Card Margin="20" UniformCornerRadius="8">
            <StackPanel Margin="30">
                <!-- 标题 -->
                <TextBlock Text="SSH密钥配置" 
                          FontSize="28" 
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,25"
                          Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <!-- 表单区域 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 别名 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" 
                              Text="别名:" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,15"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                            Text="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="如: myserver"
                            materialDesign:HintAssist.HelperText="SSH config中的Host名称"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,0,0,15"/>

                    <!-- 机器标记 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" 
                              Text="机器标记:" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,15"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                            Text="{Binding MachineMark, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="如: 我的开发机"
                            materialDesign:HintAssist.HelperText="服务器识别本机的标记（可选）"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,0,0,15"/>

                    <!-- IP地址 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" 
                              Text="IP地址:" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,15"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                            Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                            materialDesign:HintAssist.Hint="如: 192.168.1.100"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            Margin="0,0,0,15"/>

                    <!-- 用户名和端口 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" 
                              Text="用户名:" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,15"/>
                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="用户名"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBlock Grid.Column="1" 
                                  Text="端口:" 
                                  VerticalAlignment="Center"
                                  Margin="15,0,10,0"/>
                        <TextBox Grid.Column="2"
                                Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                materialDesign:HintAssist.Hint="端口"
                                Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>

                    <!-- 密码 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" 
                              Text="密码:" 
                              VerticalAlignment="Center"
                              Margin="0,0,0,15"/>
                    <PasswordBox Grid.Row="4" Grid.Column="1"
                                x:Name="PasswordBox"
                                materialDesign:HintAssist.Hint="root密码（用于临时连接）"
                                materialDesign:HintAssist.HelperText="密码仅用于本次配置，不会被保存"
                                Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                Margin="0,0,0,15"
                                PasswordChanged="PasswordBox_PasswordChanged"/>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                               Orientation="Horizontal" 
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0">
                        <Button Content="一键配置"
                               Command="{Binding ConfigureCommand}"
                               IsEnabled="{Binding IsConfigureButtonEnabled}"
                               Style="{StaticResource MaterialDesignRaisedButton}"
                               Height="40"
                               Width="120"
                               Margin="0,0,10,0"/>
                        <Button Content="测试连接"
                               Command="{Binding TestConnectionCommand}"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Height="40"
                               Width="100"
                               Margin="0,0,10,0"/>
                        <Button Content="重置"
                               Command="{Binding ResetFormCommand}"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Height="40"
                               Width="80"/>
                    </StackPanel>
                </Grid>

                <!-- 进度区域 -->
                <StackPanel Margin="0,25,0,0" 
                           Visibility="{Binding IsConfiguring, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="配置进度" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>
                    
                    <ProgressBar Value="{Binding ProgressValue}" 
                                Maximum="100"
                                Height="8"
                                Margin="0,0,0,10"/>
                    
                    <TextBlock Text="{Binding CurrentStepMessage}"
                              FontSize="14"
                              Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <!-- 错误消息 -->
                <TextBlock Text="{Binding ErrorMessage}"
                          Foreground="Red"
                          TextWrapping="Wrap"
                          Margin="0,15,0,0"
                          Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- SSH Config 输出 -->
                <StackPanel Margin="0,25,0,0"
                           Visibility="{Binding IsSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="SSH Config 配置" 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  HorizontalAlignment="Left"/>
                        <Button Content="复制配置"
                               Command="{Binding CopyConfigCommand}"
                               Style="{StaticResource MaterialDesignOutlinedButton}"
                               Height="30"
                               HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <TextBox Text="{Binding SshConfigOutput, Mode=OneWay}"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto"
                            Height="150"
                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                            FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </ScrollViewer>
</UserControl>